# Browser-exposed. Safe to expose in the Vite bundle.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
# Also supported for Supabase projects that still expose an anon key.
VITE_SUPABASE_ANON_KEY=

# Server-only. Never prefix these with VITE_.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
OPENAI_API_KEY=
